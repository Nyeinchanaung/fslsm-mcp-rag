    "    ax.bar(xi + 0.2, [r['delta'] for r in new_rows], 0.35, color=C_NEW, alpha=0.85, label='New')\n",
    "    ax.set_xticks(xi)\n",
    "    ax.set_xticklabels(poles, fontsize=9)\n",
    "    ax.set_title(dim, fontsize=10)\n",
    "    ax.axhline(0, color='k', linewidth=0.7, linestyle='--')\n",
    "    ax.set_ylabel('Engagement Lift (Δ)' if ax == axes[0] else '', fontsize=10)\n",
    "    if ax == axes[0]:\n",
