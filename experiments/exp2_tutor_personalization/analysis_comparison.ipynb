    "    ax.legend(fontsize=9)\n",
    "    ax.set_xticks([1,2,3,4,5])\n",
    "\n",
    "fig.suptitle('Fig 3 — Engagement Distribution: Old vs New Run', fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIG_DIR / 'fig3_engagement_distribution.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "11-md-fig4",
   "metadata": {},
   "source": [
    "## Fig 4 — Per-Dimension SCS Comparison\n",
    "\n",
    "SCS lift (R1−R0) per FSLSM pole, comparing old vs new. The new run shows lower overall SCS Δ because:\n",
    "- Fix B reduced pure style-filling (fewer style-only sentences → lower sentence-level SCS alignment)\n",
    "- Fix C forces factual foundation sentences first (not style-matched → dilutes SCS denominator)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "12-fig4-scs-dim",
   "metadata": {},
   "outputs": [],
   "source": [
    "DIM_MAP = {'act_ref': ('Active', 'Reflective'), 'sen_int': ('Sensing', 'Intuitive'),\n",
    "           'vis_ver': ('Visual', 'Verbal'), 'seq_glo': ('Sequential', 'Global')}\n",
    "DIM_NAMES = ['act_ref', 'sen_int', 'vis_ver', 'seq_glo']\n",
    "\n",
    "def get_dim_scs(summary, dim):\n",
    "    bd = summary.get('by_dimension', {})\n",
    "    dim_data = bd.get(dim, {})\n",
    "    rows = []\n",
    "    for pole, vals in dim_data.items():\n",
    "        scs_r0 = vals.get('SCS_R0', np.nan)\n",
    "        scs_r1 = vals.get('SCS_R1', np.nan)\n",
    "        rows.append({'pole': pole, 'delta': scs_r1 - scs_r0})\n",
    "    return rows\n",
    "\n",
    "fig, axes = plt.subplots(1, 4, figsize=(16, 5), sharey=True)\n",
    "for ax, dim in zip(axes, DIM_NAMES):\n",
    "    old_rows = get_dim_scs(old_summary, dim)\n",
    "    new_rows = get_dim_scs(new_summary, dim)\n",
    "    poles = [r['pole'] for r in old_rows]\n",
    "    xi = np.arange(len(poles))\n",
    "    ax.bar(xi - 0.2, [r['delta'] for r in old_rows], 0.35, color=C_OLD, alpha=0.85, label='Old')\n",
    "    ax.bar(xi + 0.2, [r['delta'] for r in new_rows], 0.35, color=C_NEW, alpha=0.85, label='New')\n",
    "    ax.set_xticks(xi)\n",
    "    ax.set_xticklabels(poles, fontsize=9)\n",
    "    ax.set_title(dim, fontsize=10)\n",
    "    ax.axhline(0, color='k', linewidth=0.7, linestyle='--')\n",
    "    ax.set_ylabel('SCS Lift (Δ)' if ax == axes[0] else '', fontsize=10)\n",
    "    if ax == axes[0]:\n",
    "        ax.legend(fontsize=9)\n",
    "\n",
    "fig.suptitle('Fig 4 — SCS Lift per FSLSM Dimension Pole: Old vs New Run', fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIG_DIR / 'fig4_scs_by_dimension.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "13-md-fig5",
   "metadata": {},
   "source": [
    "## Fig 5 — Per-Dimension Engagement Comparison\n",
    "\n",
    "Same layout for Engagement lift. The new run shows lower engagement Δ (old: +0.876, new: +0.643). The factual anchor (Fix C) and additive directives (Fix B) trade some style-focused engagement for factual grounding — but the RR inversion is resolved."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "14-fig5-eng-dim",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_dim_eng(summary, dim):\n",
